{
  "name": "rodno",
  "version": "0.0.0",
  "private": true,
  "description": "Rodno — nowoczesna aplikacja genealogiczna (open source). Monorepo.",
  "license": "MIT",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "api": "pnpm --filter @rodno/api",
    "web": "pnpm --filter @rodno/web"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}

# Rodno API — konfiguracja (skopiuj do .env)
PORT=5201
NODE_ENV=development

# Postgres (docker compose: host 5202 → kontener 5432)
DB_HOST=localhost
DB_PORT=5202
DB_USER=rodno
DB_PASSWORD=rodno
DB_NAME=rodno

# Auto-uruchamianie migracji przy starcie (dev). Na prod: false + jawny migration:run.
DB_RUN_MIGRATIONS=true

# Auth
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d
SEED_ADMIN_EMAIL=admin@rodno.local
SEED_ADMIN_PASSWORD=admin123
# Ważność linków (weryfikacja maila / reset hasła), w godzinach.
TOKEN_TTL_HOURS=24

# CORS dla frontu (Nuxt dev)
WEB_ORIGIN=http://localhost:5200

# Bazowy publiczny adres frontu — używany do budowy linków w mailach.
APP_PUBLIC_URL=http://localhost:5200

# Branding maili (open source — podmień pod swoją rodzinę). FAMILY_NAME puste = neutralnie.
APP_NAME=Rodno
FAMILY_NAME=
# Język powiadomień admina + fallback (pl|en|de). Maile do userów idą w ICH języku.
DEFAULT_LOCALE=pl

# SMTP — bez SMTP_HOST maile lecą do logu (tryb dev). Mailhog (docker): host=mailhog port=1025.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=Rodno <no-reply@rodno.local>
# Gdzie wysyłać powiadomienia o nowych prośbach (domyślnie = SEED_ADMIN_EMAIL).
ADMIN_NOTIFY_EMAIL=

# Media (MinIO) — publiczny bazowy URL widziany z przeglądarki
MEDIA_PUBLIC_BASE=http://localhost:5203/rodno-media
